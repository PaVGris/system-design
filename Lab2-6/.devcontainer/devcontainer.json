{
  "name": "Userver Dev",
  "dockerComposeFile": "docker-compose.yaml",
  "service": "app",
  "workspaceFolder": "/home/user/myservice",
  
  "containerEnv": {
    "CCACHE_DIR": "/home/user/myservice/.ccache",
    "CORES_DIR": "/cores",
    "PREFIX": "${PREFIX:-~/.local}",
    "SHELL": "/bin/bash"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "llvm-vs-code-extensions.vscode-clangd",
        "ms-vscode.cmake-tools",
        "ms-vscode.makefile-tools",
        "vadimcn.vscode-lldb",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "clangd.arguments": [
          "--background-index",
          "--compile-commands-dir=.vscode",
          "--clang-tidy",
          "--completion-style=detailed",
          "--header-insertion=never"
        ],
        "clangd.path": "/usr/bin/clangd",
        "cmake.automaticReconfigure": false,
        "cmake.configureOnEdit": false,
        "cmake.configureOnOpen": false,
        "cmake.copyCompileCommands": "${workspaceFolder}/.vscode/compile_commands.json"
      }
    }
  },

  "forwardPorts": [8080, 8081, 8082, 8083, 5432],
  
  "onCreateCommand": "sudo git config --global --add safe.directory /home/user/myservice",
  "postCreateCommand": "pip install faker psycopg2-binary",
  "remoteUser": "user"
}